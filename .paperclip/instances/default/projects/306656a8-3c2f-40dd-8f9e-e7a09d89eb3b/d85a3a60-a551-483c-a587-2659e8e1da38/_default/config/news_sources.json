  "apis": [
    {
      "name": "NASA APOD",
      "description": "Astronomy Picture of the Day — good for social media content",
      "endpoint": "https://api.nasa.gov/planetary/apod",
      "auth": "api_key",
      "key_env": "NASA_API_KEY",
      "free_key": "DEMO_KEY",
      "enabled": true
    },
    {
      "name": "The Space Devs Launch Library",
      "description": "Upcoming rocket launch data — powers the LANCIO section",
      "endpoint": "https://ll.thespacedevs.com/2.2.0/launch/upcoming/",
      "auth": "none",
      "docs": "https://thespacedevs.com/llapi",
      "enabled": true,
      "params": {
        "format": "json",
        "limit": 10,
        "ordering": "net"
      }
    }
